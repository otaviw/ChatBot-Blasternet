############################################
# cache
############################################
CACHE_STORE=redis
REDIS_CACHE_CONNECTION=cache
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
# REDIS_PREFIX=
# REDIS_URL=
# REDIS_USERNAME=
# REDIS_CLUSTER=redis
# REDIS_MAX_RETRIES=3
# REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
# REDIS_BACKOFF_BASE=100
# REDIS_BACKOFF_CAP=1000
# REDIS_PERSISTENT=false

MEMCACHED_HOST=127.0.0.1

############################################
# queue
############################################
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax
# Production (HTTPS): keep true. Local dev without TLS may use false.
SESSION_SECURE_COOKIE=true

############################################
# ai
############################################
AI_PROVIDER=test
AI_FALLBACK_PROVIDER=null
AI_OLLAMA_FALLBACK_PROVIDER=anthropic
AI_MODEL=test-model
AI_SYSTEM_PROMPT=
AI_TEMPERATURE=
AI_MAX_RESPONSE_TOKENS=
AI_REQUEST_TIMEOUT_MS=30000
AI_CHATBOT_FEATURE_ENABLED=false
AI_HISTORY_MESSAGES_LIMIT=20
AI_TEST_REPLY_PREFIX="[AI TEST]"
AI_NULL_FALLBACK_MESSAGE="Servico de IA indisponivel no momento."

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AI_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_ANTHROPIC_MESSAGES_PATH=/v1/messages
AI_ANTHROPIC_VERSION=2023-06-01
AI_ANTHROPIC_MAX_RESPONSE_TOKENS=1024

AI_CIRCUIT_BREAKER_ENABLED=true
AI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AI_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

AI_RAG_ENABLED=false
AI_RAG_EMBEDDING_MODEL=
AI_RAG_EMBEDDING_PATH=/api/embeddings
AI_RAG_EMBEDDING_TIMEOUT_SECONDS=15
AI_RAG_TOP_K=3
AI_RAG_CHUNK_SIZE=400
AI_RAG_CHUNK_OVERLAP=50

AI_SAFETY_FORBIDDEN_WORDS=

AI_PROMPT_ENV=
AI_PROMPT_LOGS_ENABLED=true
AI_PROMPT_HISTORY_ENABLED=true
AI_PROMPT_HISTORY_PREVIEW_CHARS=220
AI_PROMPT_SHARED_DEFAULT_VERSION=v1
AI_PROMPT_SHARED_DEFAULT_DEV=
AI_PROMPT_SHARED_DEFAULT_PROD=
AI_PROMPT_INTERNAL_CHAT_VERSION=v1
AI_PROMPT_INTERNAL_CHAT_DEV=
AI_PROMPT_INTERNAL_CHAT_PROD=
AI_PROMPT_CONVERSATION_SUGGESTION_VERSION=v1
AI_PROMPT_CONVERSATION_SUGGESTION_DEV=
AI_PROMPT_CONVERSATION_SUGGESTION_PROD=
AI_PROMPT_SANDBOX_VERSION=v1
AI_PROMPT_SANDBOX_DEV=
AI_PROMPT_SANDBOX_PROD=

AI_OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_OLLAMA_CHAT_PATH=/api/chat

############################################
# whatsapp
############################################
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_MEDIA_DISK=public
WHATSAPP_MEDIA_PREFIX=whatsapp/messages
WHATSAPP_MEDIA_MAX_SIZE_KB=5120

############################################
# realtime
############################################
REALTIME_ENABLED=true
REALTIME_CLIENT_URL=http://localhost:8081
REALTIME_JWT_SECRET=
REALTIME_JWT_ISSUER=${APP_URL}
REALTIME_JWT_AUDIENCE=realtime
REALTIME_TOKEN_TTL_SECONDS=120
REALTIME_JOIN_TOKEN_TTL_SECONDS=45
REALTIME_REDIS_CHANNEL=realtime.events
REALTIME_INTERNAL_EMIT_URL=http://localhost:8081/internal/emit
REALTIME_INTERNAL_KEY=
REALTIME_INTERNAL_TIMEOUT_MS=800
REALTIME_PUBLISH_MODE=after_response
REALTIME_PUBLISH_QUEUE=realtime
REALTIME_PRESENCE_TTL_SECONDS=40
IXC_DEBUG_LOG=false
IXC_CLIENT_ALTERNATIVE_RESOURCES=listar_clientes_por_cpf,listar_clientes_por_telefone,listar_clientes_fibra

############################################
# observability
############################################
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=

RATE_LIMIT_LOGIN=5
RATE_LIMIT_PASSWORD_RESET=5
RATE_LIMIT_WEBHOOK_INBOUND=500
RATE_LIMIT_API_GLOBAL=600
RATE_LIMIT_BOT_WRITE=60
RATE_LIMIT_SIMULATION=30
RATE_LIMIT_INBOX_READ=180
RATE_LIMIT_CONVERSATION_SEARCH=30
RATE_LIMIT_REALTIME_TOKEN=30
RATE_LIMIT_REALTIME_JOIN=120

