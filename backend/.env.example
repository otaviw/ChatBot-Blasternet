APP_NAME=Laravel
APP_ENV=local
# [OBRIGATÓRIO] Gere com: php artisan key:generate
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ---------------------------------------------------------------------------
# Monitoramento de erros — Sentry (opcional)
# Obter o DSN em: sentry.io → Projeto → Settings → Client Keys (DSN)
# Deixar vazio em desenvolvimento para não enviar erros locais.
# ---------------------------------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Banco de dados
# Em desenvolvimento local, SQLite funciona sem configuração adicional.
# Em produção, descomente e preencha as linhas abaixo.
# ---------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=nome_do_banco
# DB_USERNAME=usuario_do_banco
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Em produção: SESSION_SECURE_COOKIE=true (cookies apenas via HTTPS)
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default

CACHE_STORE=redis
REDIS_CACHE_CONNECTION=cache
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Realtime — autenticação JWT e emissão de eventos
#
# [OBRIGATÓRIO] Gere os secrets com:
#   php artisan app:generate-secrets --write
#
# REALTIME_JWT_SECRET  — assina todos os tokens JWT emitidos pelo backend.
#                        Mínimo recomendado: 64 bytes aleatórios (128 hex chars).
#                        A aplicação HTTP recusa subir se este valor estiver vazio
#                        ou contiver um placeholder.
#
# REALTIME_INTERNAL_KEY — protege o endpoint interno /internal/emit do servidor
#                         realtime. Obrigatório apenas quando
#                         REALTIME_INTERNAL_EMIT_URL estiver configurado.
# ---------------------------------------------------------------------------
REALTIME_ENABLED=true
REALTIME_CLIENT_URL=http://localhost:8081
REALTIME_JWT_SECRET=
REALTIME_JWT_ISSUER=${APP_URL}
REALTIME_JWT_AUDIENCE=realtime
REALTIME_TOKEN_TTL_SECONDS=120
REALTIME_JOIN_TOKEN_TTL_SECONDS=45
# Sufixo base do canal. Se REDIS_PREFIX estiver ativo, o Laravel publica como
# "{REDIS_PREFIX}{REALTIME_REDIS_CHANNEL}" automaticamente.
REALTIME_REDIS_CHANNEL=realtime.events
REALTIME_INTERNAL_EMIT_URL=http://localhost:8081/internal/emit
REALTIME_INTERNAL_KEY=
REALTIME_INTERNAL_TIMEOUT_MS=800
REALTIME_PUBLISH_MODE=after_response
REALTIME_PUBLISH_QUEUE=realtime
REALTIME_PRESENCE_TTL_SECONDS=40

# ---------------------------------------------------------------------------
# IA — provider, modelo e timeouts
# ---------------------------------------------------------------------------
AI_PROVIDER=test
AI_FALLBACK_PROVIDER=null
AI_OLLAMA_FALLBACK_PROVIDER=anthropic
AI_MODEL=test-model
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AI_SYSTEM_PROMPT=
AI_TEMPERATURE=
AI_MAX_RESPONSE_TOKENS=
AI_HISTORY_MESSAGES_LIMIT=20
AI_REQUEST_TIMEOUT_MS=30000
AI_CIRCUIT_BREAKER_ENABLED=true
AI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AI_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
AI_PROMPT_ENV=
AI_PROMPT_LOGS_ENABLED=true
AI_PROMPT_HISTORY_ENABLED=true
AI_PROMPT_HISTORY_PREVIEW_CHARS=220
AI_PROMPT_SHARED_DEFAULT_VERSION=v1
AI_PROMPT_SHARED_DEFAULT_DEV=
AI_PROMPT_SHARED_DEFAULT_PROD=
AI_PROMPT_INTERNAL_CHAT_VERSION=v1
AI_PROMPT_INTERNAL_CHAT_DEV=
AI_PROMPT_INTERNAL_CHAT_PROD=
AI_PROMPT_CONVERSATION_SUGGESTION_VERSION=v1
AI_PROMPT_CONVERSATION_SUGGESTION_DEV=
AI_PROMPT_CONVERSATION_SUGGESTION_PROD=
AI_PROMPT_SANDBOX_VERSION=v1
AI_PROMPT_SANDBOX_DEV=
AI_PROMPT_SANDBOX_PROD=
AI_OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_OLLAMA_CHAT_PATH=/api/chat
AI_TEST_REPLY_PREFIX="[AI TEST]"
AI_NULL_FALLBACK_MESSAGE="Servico de IA indisponivel no momento."

# ---------------------------------------------------------------------------
# Rate limits — lidos via config/rate_limits.php (compatível com config:cache)
# ---------------------------------------------------------------------------
RATE_LIMIT_LOGIN=5
RATE_LIMIT_PASSWORD_RESET=5
RATE_LIMIT_WEBHOOK_INBOUND=500
RATE_LIMIT_API_GLOBAL=600
RATE_LIMIT_BOT_WRITE=60
RATE_LIMIT_SIMULATION=30
RATE_LIMIT_INBOX_READ=180
RATE_LIMIT_CONVERSATION_SEARCH=30
RATE_LIMIT_REALTIME_TOKEN=30
RATE_LIMIT_REALTIME_JOIN=120

# ---------------------------------------------------------------------------
# E-mail
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@seudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# AWS (opcional — S3, SES)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# WhatsApp — Meta for Developers
#
# Todos os valores abaixo devem ser preenchidos com credenciais reais do seu
# aplicativo no Meta for Developers (developers.facebook.com).
#
# WHATSAPP_VERIFY_TOKEN  — token de verificação escolhido por você ao configurar
#                          o webhook no painel Meta. Pode ser gerado com:
#                          php artisan app:generate-secrets
#
# WHATSAPP_PHONE_NUMBER_ID — ID numérico do número de telefone (não o número).
#                            Encontrado em: Meta → App → WhatsApp → Configuração.
#
# WHATSAPP_ACCESS_TOKEN  — token de acesso permanente ou temporário da API.
#                          Gere em: Meta → App → WhatsApp → Configuração de API.
#
# WHATSAPP_APP_SECRET    — [OBRIGATÓRIO] chave secreta do App.
#                          Localização: Meta → Configurações do app → Básico.
#                          Usada para validar X-Hub-Signature-256 dos webhooks.
#                          A aplicação HTTP não sobe sem este valor configurado.
# ---------------------------------------------------------------------------
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
