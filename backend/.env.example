APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Sentry — monitoramento de erros em produção
# Obter o DSN em: sentry.io → Projeto → Settings → Client Keys (DSN)
# Deixar vazio em desenvolvimento para não enviar erros locais
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Em produção, definir como true para enviar cookie apenas via HTTPS
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default

CACHE_STORE=redis
REDIS_CACHE_CONNECTION=cache
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

REALTIME_ENABLED=true
REALTIME_CLIENT_URL=http://localhost:8081
REALTIME_JWT_SECRET=change_this_realtime_jwt_secret
REALTIME_JWT_ISSUER=${APP_URL}
REALTIME_JWT_AUDIENCE=realtime
REALTIME_TOKEN_TTL_SECONDS=120
REALTIME_JOIN_TOKEN_TTL_SECONDS=45
# Sufixo base do canal. Se REDIS_PREFIX estiver ativo, o Laravel publica como
# "{REDIS_PREFIX}{REALTIME_REDIS_CHANNEL}" automaticamente.
REALTIME_REDIS_CHANNEL=realtime.events
REALTIME_INTERNAL_EMIT_URL=http://localhost:8081/internal/emit
REALTIME_INTERNAL_KEY=change_this_internal_emit_key
REALTIME_INTERNAL_TIMEOUT_MS=800
REALTIME_PUBLISH_MODE=after_response
REALTIME_PUBLISH_QUEUE=realtime
REALTIME_PRESENCE_TTL_SECONDS=40

AI_PROVIDER=test
AI_FALLBACK_PROVIDER=null
AI_MODEL=test-model
AI_SYSTEM_PROMPT=
AI_TEMPERATURE=
AI_MAX_RESPONSE_TOKENS=
AI_HISTORY_MESSAGES_LIMIT=20
AI_REQUEST_TIMEOUT_MS=30000
AI_OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_OLLAMA_CHAT_PATH=/api/chat
AI_TEST_REPLY_PREFIX="[AI TEST]"
AI_NULL_FALLBACK_MESSAGE="Servico de IA indisponivel no momento."

# Rate limits lidos via config/rate_limits.php para funcionar com config:cache em producao.
RATE_LIMIT_LOGIN=5
RATE_LIMIT_PASSWORD_RESET=5
RATE_LIMIT_WEBHOOK_INBOUND=500
RATE_LIMIT_API_GLOBAL=600
RATE_LIMIT_BOT_WRITE=60
RATE_LIMIT_SIMULATION=30
RATE_LIMIT_INBOX_READ=180
RATE_LIMIT_CONVERSATION_SEARCH=30
RATE_LIMIT_REALTIME_TOKEN=30
RATE_LIMIT_REALTIME_JOIN=120

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@seudominio.com"  # endereço remetente dos e-mails automáticos
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WhatsApp (Meta for Developers) — preencher quando tiver o app
WHATSAPP_VERIFY_TOKEN=verify_token_chatbot_blasternet
WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_PHONE_NUMBER_ID=change_this_phone_number_id
WHATSAPP_ACCESS_TOKEN=change_this_whatsapp_access_token

# OBRIGATÓRIO: chave secreta do App (Meta for Developers → Configurações do app → Básico → Chave secreta do app).
# Usada para validar a assinatura X-Hub-Signature-256 de cada webhook recebido.
# A aplicação HTTP não sobe sem este valor configurado.
WHATSAPP_APP_SECRET=change_this_to_your_meta_app_secret
