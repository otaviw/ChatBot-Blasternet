############################################
# app
############################################
# Preferred: explicit full API URL. Fallbacks are VITE_API_BASE then /api.
VITE_API_URL=http://localhost:8000/api
VITE_API_BASE=/api

############################################
# realtime
############################################
VITE_REALTIME_URL=http://localhost:8081
VITE_INTERNAL_CHAT_ENABLE_LEGACY_ENDPOINTS=0

############################################
# observability
############################################
VITE_SENTRY_DSN=
# e.g. development, staging, production
VITE_SENTRY_ENVIRONMENT=
# release identifier shown in Sentry
VITE_APP_VERSION=
