VITE_API_BASE=/api
VITE_REALTIME_URL=http://localhost:8081
VITE_INTERNAL_CHAT_ENABLE_LEGACY_ENDPOINTS=0

# ---------------------------------------------------------------------------
# Sentry — monitoramento de erros no frontend
# Obter o DSN em: sentry.io → Projeto → Settings → Client Keys (DSN)
# Deixar vazio para desativar (recomendado em desenvolvimento).
# ---------------------------------------------------------------------------
VITE_SENTRY_DSN=
# Ambiente exibido no Sentry (ex: staging, production).
# Se vazio, usa o mode do Vite ('development' | 'production').
VITE_SENTRY_ENVIRONMENT=
# Versão do app exibida no Sentry para rastrear releases.
VITE_APP_VERSION=
