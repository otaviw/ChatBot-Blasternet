############################################
# app
############################################
NODE_ENV=development
REALTIME_HOST=0.0.0.0
REALTIME_PORT=8081

############################################
# db / cache / queue
############################################
# Realtime service uses Redis pub/sub (no SQL database).
REALTIME_REDIS_URL=redis://127.0.0.1:6379
REALTIME_REDIS_CHANNEL=realtime.events

############################################
# realtime
############################################
REALTIME_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
REALTIME_JWT_SECRET=
REALTIME_JWT_ISSUER=http://localhost
REALTIME_JWT_AUDIENCE=realtime
REALTIME_INTERNAL_KEY=

############################################
# observability
############################################
REALTIME_LOG_LEVEL=info
