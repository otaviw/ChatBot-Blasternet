NODE_ENV=development
REALTIME_HOST=0.0.0.0
REALTIME_PORT=8081
REALTIME_CORS_ORIGINS=http://localhost:5173

REALTIME_JWT_SECRET=change_this_realtime_jwt_secret
REALTIME_JWT_ISSUER=http://localhost
REALTIME_JWT_AUDIENCE=realtime

REALTIME_REDIS_URL=redis://127.0.0.1:6379
REALTIME_REDIS_CHANNEL=realtime.events

REALTIME_INTERNAL_KEY=change_this_internal_emit_key
REALTIME_LOG_LEVEL=info
